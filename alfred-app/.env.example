###################
# CHAT MODEL (LLM)
###################

# Provider: either "azure" | "openai"
CHAT_PROVIDER=azure

# --- Azure (chat) ---
AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_API_VERSION=xxxx-xx-xx
AZURE_OPENAI_BASE_URL=https://xxxxxxxx.cloud/openai/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.1

# --- OpenAI / compatible (chat) ---
OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://xxxxxxxxxxxx/v1
OPENAI_CHAT_MODEL=gpt-5.1

##################
# EMBEDDING MODEL
##################

# Provider: either "azure" | "openai"
EMBEDDING_PROVIDER=openai

# --- Azure (embeddings) ---
AZURE_OPENAI_EMBEDDING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_EMBEDDING_API_VERSION=xxxx-xx-xx
AZURE_OPENAI_EMBEDDING_BASE_URL=https://xxxxxxxx.cloud/openai/
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# --- OpenAI / compatible (embeddings) ---
OPENAI_EMBEDDING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_BASE_URL=https://xxxxxxxxxxxx/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

########################################
# DATABRICKS (SQL / DATA)
########################################

DATABRICKS_HOST=dbc-xxxxxxxxxxxx.databricks.com
DATABRICKS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABRICKS_WAREHOUSE_ID=exxxxxxxxx
DATABRICKS_CATALOG=xxxxxxxxxxxxxxxxxxxxx
DATABRICKS_SCHEMA=xxxxxxxxxxxxxxxxx

########################################
# NEO4J (GRAPH)
########################################

NEO4J_BOLT_URL=bolt://xxxxxxx:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

########################################
# OLLAMA (OPTIONAL WEB SEARCH / WEB FETCH)
########################################
OLLAMA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx